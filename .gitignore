*.sublime-project

# Logs and Debug
error.log
access.log
debug.log
*.log.*

# Cache and Sessions
cache/
sessions/
tmp/

# Uploaded Files (keep structure, ignore actual uploads)
images/uploads/*
!images/uploads/.gitkeep

# User Uploads
uploads/
user_files/

# Composer (if using)
vendor/
composer.lock

# Node.js (if using for build tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

